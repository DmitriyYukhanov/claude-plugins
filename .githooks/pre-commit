#!/bin/bash
# Pre-commit hook: enforce plugin version bumps, marketplace sync, and new plugin registration
#
# Checks:
# 1. When files inside plugins/<name>/ change, plugin.json version must be bumped
# 2. When plugin.json version changes, marketplace.json must match
# 3. When a new plugin directory appears, it must be registered in marketplace.json and README.md
#
# Follows Keep a Changelog / Semantic Versioning conventions.
# To bypass (emergency only): git commit --no-verify

set -euo pipefail

MARKETPLACE=".claude-plugin/marketplace.json"

# Get list of staged files (added, modified, deleted)
staged_files=$(git diff --cached --name-only --diff-filter=ACDMR 2>/dev/null || true)

if [ -z "$staged_files" ]; then
  exit 0
fi

# Collect unique plugin names that have changed files (excluding plugin.json itself)
changed_plugins=()
while IFS= read -r file; do
  if [[ "$file" =~ ^plugins/([^/]+)/ ]] && [[ "$file" != plugins/*/plugin.json ]]; then
    plugin_name="${BASH_REMATCH[1]}"
    # Deduplicate
    if [[ ! " ${changed_plugins[*]:-} " =~ " ${plugin_name} " ]]; then
      changed_plugins+=("$plugin_name")
    fi
  fi
done <<< "$staged_files"

# ── Check 1: plugin.json version bump ──────────────────────────────────

version_errors=()
if [ ${#changed_plugins[@]} -gt 0 ]; then
  for plugin in "${changed_plugins[@]}"; do
    plugin_json="plugins/${plugin}/plugin.json"

    # Check if plugin.json is in the staged files
    if ! echo "$staged_files" | grep -qx "$plugin_json"; then
      version_errors+=("$plugin")
      continue
    fi

    # Check if the version field actually changed
    old_version=$(git show "HEAD:${plugin_json}" 2>/dev/null | grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' | grep -o '[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*' || echo "0.0.0")
    new_version=$(git show ":${plugin_json}" 2>/dev/null | grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' | grep -o '[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*' || echo "0.0.0")

    if [ "$old_version" = "$new_version" ]; then
      version_errors+=("$plugin")
    fi
  done
fi

# ── Check 2: marketplace.json version sync ─────────────────────────────

# Collect all plugins whose plugin.json version changed (staged)
sync_errors=()
for plugin_json in $(echo "$staged_files" | grep -E '^plugins/[^/]+/plugin\.json$' || true); do
  plugin_name=$(echo "$plugin_json" | sed 's|plugins/\([^/]*\)/plugin\.json|\1|')

  # Get the new version from staged plugin.json
  plugin_version=$(git show ":${plugin_json}" 2>/dev/null | grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' | grep -o '[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*' || echo "")

  if [ -z "$plugin_version" ]; then
    continue
  fi

  # Get the marketplace version that will be in the commit:
  # - If marketplace.json is staged, use the staged version
  # - If not staged, use HEAD (what the commit will contain)
  if echo "$staged_files" | grep -qx "$MARKETPLACE"; then
    marketplace_content=$(git show ":${MARKETPLACE}" 2>/dev/null || echo "")
  else
    marketplace_content=$(git show "HEAD:${MARKETPLACE}" 2>/dev/null || echo "")
  fi

  if [ -z "$marketplace_content" ]; then
    continue
  fi

  # Extract version for this plugin from marketplace.json
  # Use awk to find the plugin block by name and extract its version
  marketplace_version=$(echo "$marketplace_content" | awk -v name="$plugin_name" '
    /"name"/ { found = ($0 ~ "\"" name "\"") }
    found && /"version"/ { match($0, /[0-9]+\.[0-9]+\.[0-9]+/); print substr($0, RSTART, RLENGTH); found=0 }
  ')

  if [ -n "$marketplace_version" ] && [ "$plugin_version" != "$marketplace_version" ]; then
    sync_errors+=("${plugin_name}: plugin.json=${plugin_version}, marketplace.json=${marketplace_version}")
  fi
done

# ── Check 3: new plugin registration (README + marketplace) ───────────

readme_errors=()
marketplace_missing=()

# Collect ALL plugin names with any staged file (including plugin.json)
all_staged_plugins=()
while IFS= read -r file; do
  if [[ "$file" =~ ^plugins/([^/]+)/ ]]; then
    pname="${BASH_REMATCH[1]}"
    if [[ ! " ${all_staged_plugins[*]:-} " =~ " ${pname} " ]]; then
      all_staged_plugins+=("$pname")
    fi
  fi
done <<< "$staged_files"

for plugin in "${all_staged_plugins[@]}"; do
  plugin_json="plugins/${plugin}/plugin.json"

  # Detect NEW plugins: plugin.json is staged AND didn't exist in HEAD
  if echo "$staged_files" | grep -qx "$plugin_json"; then
    if ! git show "HEAD:${plugin_json}" &>/dev/null; then
      # This is a brand-new plugin

      # Check marketplace.json has an entry for this plugin
      if echo "$staged_files" | grep -qx "$MARKETPLACE"; then
        marketplace_content=$(git show ":${MARKETPLACE}" 2>/dev/null || echo "")
      else
        marketplace_content=$(cat "$MARKETPLACE" 2>/dev/null || echo "")
      fi
      if ! echo "$marketplace_content" | grep -q "\"$plugin\""; then
        marketplace_missing+=("$plugin")
      fi

      # Check README.md mentions this plugin
      if echo "$staged_files" | grep -qx "README.md"; then
        readme_content=$(git show ":README.md" 2>/dev/null || echo "")
      else
        readme_content=$(cat "README.md" 2>/dev/null || echo "")
      fi
      if ! echo "$readme_content" | grep -q "### $plugin"; then
        readme_errors+=("$plugin")
      fi
    fi
  fi
done

# ── Report errors ──────────────────────────────────────────────────────

has_errors=false

if [ ${#version_errors[@]} -gt 0 ]; then
  has_errors=true
  echo ""
  echo "ERROR: Plugin version bump required"
  echo "========================================"
  echo ""
  echo "The following plugins have changed files but no version bump in plugin.json:"
  echo ""
  for plugin in "${version_errors[@]}"; do
    plugin_json="plugins/${plugin}/plugin.json"
    current=$(cat "$plugin_json" 2>/dev/null | grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' | grep -o '[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*' || echo "unknown")
    echo "  - plugins/${plugin}/  (current version: ${current})"
  done
  echo ""
  echo "Versioning guide (Semantic Versioning / Keep a Changelog):"
  echo "  PATCH (x.y.Z) — bug fixes, typo corrections, minor tweaks"
  echo "  MINOR (x.Y.0) — new features, skill improvements, non-breaking changes"
  echo "  MAJOR (X.0.0) — breaking changes, major restructuring"
  echo ""
  echo "Fix: update \"version\" in the plugin's plugin.json, then re-stage and commit."
fi

if [ ${#sync_errors[@]} -gt 0 ]; then
  has_errors=true
  echo ""
  echo "ERROR: marketplace.json version mismatch"
  echo "========================================"
  echo ""
  echo "The following plugins have mismatched versions between plugin.json and marketplace.json:"
  echo ""
  for err in "${sync_errors[@]}"; do
    echo "  - ${err}"
  done
  echo ""
  echo "Fix: update the version in ${MARKETPLACE} to match, then re-stage and commit."
fi

if [ ${#marketplace_missing[@]} -gt 0 ]; then
  has_errors=true
  echo ""
  echo "ERROR: New plugin missing from marketplace.json"
  echo "========================================"
  echo ""
  echo "The following new plugins are not listed in ${MARKETPLACE}:"
  echo ""
  for plugin in "${marketplace_missing[@]}"; do
    echo "  - ${plugin}"
  done
  echo ""
  echo "Fix: add an entry for the plugin in ${MARKETPLACE}, then re-stage and commit."
fi

if [ ${#readme_errors[@]} -gt 0 ]; then
  has_errors=true
  echo ""
  echo "ERROR: New plugin missing from README.md"
  echo "========================================"
  echo ""
  echo "The following new plugins are not documented in README.md:"
  echo ""
  for plugin in "${readme_errors[@]}"; do
    echo "  - ${plugin}"
  done
  echo ""
  echo "Fix: add an install command and a ### <plugin-name> section to README.md, then re-stage and commit."
fi

if [ "$has_errors" = true ]; then
  echo ""
  echo "Bypass (emergency only): git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
