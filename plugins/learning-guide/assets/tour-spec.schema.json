{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DmitriyYukhanov/claude-plugins/learning-guide/tour-spec-1.0.json",
  "title": "Tour Spec",
  "type": "object",
  "required": ["schema_version", "title", "lang", "archetype", "sections"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.\\d+$" },
    "title":          { "type": "string", "minLength": 1, "maxLength": 200 },
    "subtitle":       { "type": "string", "maxLength": 200 },
    "lang":           { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "archetype": {
      "type": "string",
      "enum": ["codebase", "planning-session", "refactor-plan", "generic"]
    },
    "embedded_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/embeddedSource" }
    },
    "external_links": {
      "type": "object",
      "patternProperties": {
        "^[A-Z][A-Z0-9]*-$": { "type": "string", "pattern": "^(https?|mailto):.*\\{id\\}" }
      },
      "additionalProperties": false
    },
    "cross_ref_patterns": {
      "type": "array",
      "items": { "$ref": "#/$defs/crossRefPattern" }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    },
    "final_quiz":  { "type": "array", "items": { "$ref": "#/$defs/quizItem" } },
    "glossary":    { "type": "array", "items": { "$ref": "#/$defs/glossaryEntry" } },
    "renderer":    { "$ref": "#/$defs/rendererHints" }
  },
  "$defs": {
    "embeddedSource": {
      "type": "object",
      "required": ["name", "path", "label"],
      "additionalProperties": false,
      "properties": {
        "name":  { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "path":  { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "crossRefPattern": {
      "type": "object",
      "required": ["pattern", "source"],
      "additionalProperties": false,
      "properties": {
        "pattern":       { "type": "string", "minLength": 1 },
        "source":        { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "anchor_format": { "type": ["string", "null"] }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "level", "title", "body_md"],
      "additionalProperties": false,
      "properties": {
        "id":                 { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "level":              { "type": "integer", "minimum": 1, "maximum": 3 },
        "parent":             { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "title":              { "type": "string", "minLength": 1, "maxLength": 200 },
        "estimated_minutes":  { "type": "integer", "minimum": 1, "maximum": 240 },
        "body_md":            { "type": "string", "minLength": 1 },
        "quiz":               { "type": "array", "items": { "$ref": "#/$defs/quizItem" } }
      },
      "if":   { "properties": { "level": { "minimum": 2 } } },
      "then": { "required": ["parent"] }
    },
    "quizItem": {
      "type": "object",
      "required": ["question", "options", "answer_index"],
      "additionalProperties": false,
      "properties": {
        "question":     { "type": "string", "minLength": 1 },
        "options":      { "type": "array", "minItems": 2, "maxItems": 8, "items": { "type": "string", "minLength": 1 } },
        "answer_index": { "type": "integer", "minimum": 0 },
        "explanation":  { "type": "string" }
      }
    },
    "glossaryEntry": {
      "type": "object",
      "required": ["term", "definition"],
      "additionalProperties": false,
      "properties": {
        "term":       { "type": "string", "minLength": 1 },
        "definition": { "type": "string", "minLength": 1 }
      }
    },
    "rendererHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include_mermaid":               { "type": ["boolean", "null"] },
        "include_progress_tracker":      { "type": "boolean" },
        "include_pager":                 { "type": "boolean" },
        "open_command":                  { "type": "string", "enum": ["open.cmd", "none"] },
        "max_inline_payload_kb":         { "type": ["integer", "null"], "minimum": 1 },
        "template_compatibility_version":{ "type": "string", "pattern": "^[0-9]+$" }
      }
    }
  }
}
